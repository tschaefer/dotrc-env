[core]
    pager = bat --plain
    editor = vim
    excludesFile = ~/.git/gitignore

[color]
    ui = true
    branch = auto
    diff = auto
    interactive = auto
    status = auto

[apply]
    whitespace = strip

[diff]
    color = auto
    colorMoved = default
    rename = copy

[pager]
    color = true

[rerere]
    enabled = true

[status]
    color = auto

[push]
    default = simple
    autoSetupRemote = true

[pull]
    ff = only

[rebase]
    autoStash = true

[init]
    defaultBranch = main

[merge]
    conflictStyle = diff3

[include]
    path = ~/.git/gitconfig.local

